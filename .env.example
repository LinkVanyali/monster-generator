ANTHROPIC_API_KEY=sk-ant-...
HF_TOKEN=hf_...

# Optional: override the image generation model (default: black-forest-labs/FLUX.1-schnell)
# IMAGE_MODEL=black-forest-labs/FLUX.1-dev

# Optional: Foundry VTT data directory for auto-copying token images
# When set, /save will write token images to {FOUNDRY_DATA}/monsters/ so Plutonium can resolve them
# Example: FOUNDRY_DATA=/home/foundry/Data
